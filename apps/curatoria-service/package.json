{
  "name": "@curatoria/service",
  "version": "1.0.0",
  "private": true,
  "description": "Curatoria API and x402 paywall service workspace",
  "main": "../../dist/server.js",
  "scripts": {
    "start": "node -r ts-node/register ../../src/server.ts",
    "dev": "ts-node-dev --respawn --transpile-only ../../src/server.ts",
    "publish-design": "ts-node ../../scripts/publish.ts",
    "publish-pack": "ts-node ../../scripts/publish-pack.ts",
    "smoke": "ts-node ../../scripts/smoke.ts",
    "bug-bash": "ts-node ../../scripts/bug-bash.ts",
    "build": "tsc -p ../../tsconfig.json"
  },
  "dependencies": {
    "@coinbase/x402": "^2.1.0",
    "@x402/core": "^2.15.0",
    "@x402/evm": "^2.15.0",
    "@x402/express": "^2.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
