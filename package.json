{
  "name": "curatoria-starter",
  "version": "0.1.0",
  "private": true,
  "description": "Starter template for creator-owned x402 paywalled design resources",
  "homepage": "https://github.com/margaretsommers/curatoria-starter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/margaretsommers/curatoria-starter.git"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @curatoria/service",
    "start": "npm run start --workspace @curatoria/service",
    "build": "npm run build --workspace @curatoria/service",
    "smoke": "npm run smoke --workspace @curatoria/service",
    "bug-bash": "npm run bug-bash --workspace @curatoria/service --",
    "publish-design": "npm run publish-design --workspace @curatoria/service --",
    "publish-pack": "npm run publish-pack --workspace @curatoria/service --",
    "dev:site": "npm run dev --workspace @curatoria/site",
    "start:site": "npm run start --workspace @curatoria/site"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "axios": "1.18.0",
    "form-data": "4.0.6",
    "qs": "6.15.2",
    "ws": "8.21.0"
  },
  "dependencies": {
    "@x402/core": "^2.15.0",
    "@x402/evm": "^2.15.0",
    "@x402/express": "^2.15.0",
    "@x402/extensions": "^2.15.0"
  }
}
