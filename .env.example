WALLET_ADDRESS=0xYOUR_BASE_WALLET
WALLET_ENS=yourname.eth
ADMIN_API_KEY=change-me-admin-key
NETWORK=base-sepolia
PORT=3000
FACILITATOR_URL=https://x402.org/facilitator

# ─── Storage connectors (optional) ────────────────────────────────────────────
# Products can be sourced from a local design-systems/ file (default), a direct
# https URL you control, a Google Drive file, or Dropbox (Mode A share link /
# Mode B private path via OAuth). Local, URL, and Dropbox Mode A need no extra config.
#
# GOOGLE_API_KEY: optional. A Google Cloud API key with the Drive API enabled.
# Set it to serve private or large Drive files reliably. Without it, Drive
# sources still work for files shared "Anyone with the link can view".
GOOGLE_API_KEY=
# STORAGE_MAX_BYTES: max size for a remote (url/gdrive) product (default 50 MB).
# STORAGE_MAX_BYTES=52428800
# STORAGE_FETCH_TIMEOUT_MS: remote fetch timeout in ms (default 15000).
# STORAGE_FETCH_TIMEOUT_MS=15000
#
# Dropbox connector (Mode B OAuth/private-file path) — only needed when using
# --dropbox-path in publish commands.
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=
# DROPBOX_REFRESH_TOKEN=
